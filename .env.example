# Database URL
# For local Docker: postgresql://transitops:transitops_dev_password@localhost:5432/transitops?schema=public
# For Neon: postgresql://user:password@host.neon.tech/database
# For Supabase: postgresql://postgres:password@db.project.supabase.co:5432/postgres
DATABASE_URL="postgresql://transitops:transitops_dev_password@localhost:5432/transitops?schema=public"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-random-secret"

# Chatbot backend (Node application)
# Point this to the chatbot API endpoint that handles DB access.
CHATBOT_BACKEND_URL="http://localhost:4000/chat"
