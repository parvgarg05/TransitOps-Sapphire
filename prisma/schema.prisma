// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// ENUMS
// ========================================

enum RoleType {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

// ========================================
// MODELS
// ========================================

model Role {
  id    String   @id @default(cuid())
  name  RoleType @unique
  users User[]

  @@map("roles")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique @db.VarChar(254)
  passwordHash    String
  roleId          String
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())

  role  Role   @relation(fields: [roleId], references: [id])
  trips Trip[]

  @@index([email])
  @@map("users")
}

model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  type               String
  region             String?
  maxLoadCapacity    Decimal       @db.Decimal(10, 2) // kg (0 < x <= 100,000)
  odometer           Decimal       @db.Decimal(12, 2) // km (0 <= x <= 10,000,000)
  acquisitionCost    Decimal       @db.Decimal(12, 2) // currency (>= 0)
  revenue            Decimal       @default(0) @db.Decimal(12, 2) // for ROI calculation
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())

  trips             Trip[]
  maintenanceLogs   MaintenanceLog[]
  fuelLogs          FuelLog[]
  expenses          Expense[]
  vehicleDocuments  VehicleDocument[]

  @@index([status])
  @@index([registrationNumber])
  @@map("vehicles")
}

model Driver {
  id                String       @id @default(cuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime     @db.Date
  contactNumber     String
  safetyScore       Decimal      @db.Decimal(5, 2) // 0 <= x <= 100
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())

  trips Trip[]

  @@index([status])
  @@index([licenseNumber])
  @@map("drivers")
}

model Trip {
  id              String     @id @default(cuid())
  source          String
  destination     String
  vehicleId       String
  driverId        String
  createdByUserId String
  cargoWeight     Decimal    @db.Decimal(10, 2) // kg (> 0)
  plannedDistance Decimal    @db.Decimal(10, 2) // km (> 0)
  finalOdometer   Decimal?   @db.Decimal(12, 2) // km, nullable until completed
  fuelConsumed    Decimal?   @db.Decimal(10, 2) // liters, nullable until completed (>= 0)
  status          TripStatus @default(DRAFT)
  createdAt       DateTime   @default(now())

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  driver    Driver  @relation(fields: [driverId], references: [id])
  createdBy User    @relation(fields: [createdByUserId], references: [id])

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id          String    @id @default(cuid())
  vehicleId   String
  description String
  cost        Decimal   @default(0) @db.Decimal(12, 2) // 0 <= x <= 999,999,999.99
  closed      Boolean   @default(false) // false = active record
  openedAt    DateTime  @default(now())
  closedAt    DateTime?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([closed])
  @@map("maintenance_logs")
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  liters    Decimal  @db.Decimal(10, 2) // > 0
  cost      Decimal  @db.Decimal(10, 2) // >= 0
  date      DateTime @db.Date // <= today
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@map("fuel_logs")
}

model Expense {
  id        String   @id @default(cuid())
  vehicleId String
  category  String // toll, maintenance charge, other
  cost      Decimal  @db.Decimal(12, 2) // >= 0
  date      DateTime @db.Date // <= today
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@map("expenses")
}

// ========================================
// BONUS: VEHICLE DOCUMENT MANAGEMENT (Requirement 14)
// ========================================

model VehicleDocument {
  id         String   @id @default(cuid())
  vehicleId  String
  filename   String
  url        String
  uploadedAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("vehicle_documents")
}
