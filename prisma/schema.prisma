generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id    String   @id @default(cuid())
  name  RoleType @unique
  users User[]

  @@map("roles")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique @db.VarChar(254)
  passwordHash   String
  roleId         String
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  trips          Trip[]
  role           Role      @relation(fields: [roleId], references: [id])

  @@index([email])
  @@map("users")
}

model Vehicle {
  id                 String            @id @default(cuid())
  registrationNumber String            @unique
  name               String
  type               String
  region             String?
  maxLoadCapacity    Decimal           @db.Decimal(10, 2)
  odometer           Decimal           @db.Decimal(12, 2)
  acquisitionCost    Decimal           @db.Decimal(12, 2)
  revenue            Decimal           @default(0) @db.Decimal(12, 2)
  status             VehicleStatus     @default(AVAILABLE)
  createdAt          DateTime          @default(now())
  expenses           Expense[]
  fuelLogs           FuelLog[]
  maintenanceLogs    MaintenanceLog[]
  trips              Trip[]
  vehicleDocuments   VehicleDocument[]

  @@index([status])
  @@index([registrationNumber])
  @@map("vehicles")
}

model Driver {
  id                String       @id @default(cuid())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime     @db.Date
  contactNumber     String
  safetyScore       Decimal      @db.Decimal(5, 2)
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  trips             Trip[]

  @@index([status])
  @@index([licenseNumber])
  @@map("drivers")
}

model Trip {
  id              String     @id @default(cuid())
  source          String
  destination     String
  vehicleId       String
  driverId        String
  createdByUserId String
  cargoWeight     Decimal    @db.Decimal(10, 2)
  plannedDistance Decimal    @db.Decimal(10, 2)
  finalOdometer   Decimal?   @db.Decimal(12, 2)
  fuelConsumed    Decimal?   @db.Decimal(10, 2)
  status          TripStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  createdBy       User       @relation(fields: [createdByUserId], references: [id])
  driver          Driver     @relation(fields: [driverId], references: [id])
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id])

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
  @@map("trips")
}

model MaintenanceLog {
  id          String    @id @default(cuid())
  vehicleId   String
  description String
  cost        Decimal   @default(0) @db.Decimal(12, 2)
  closed      Boolean   @default(false)
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([closed])
  @@map("maintenance_logs")
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  liters    Decimal  @db.Decimal(10, 2)
  cost      Decimal  @db.Decimal(10, 2)
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@map("fuel_logs")
}

model Expense {
  id        String   @id @default(cuid())
  vehicleId String
  category  String
  cost      Decimal  @db.Decimal(12, 2)
  date      DateTime @db.Date
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@index([date])
  @@map("expenses")
}

model VehicleDocument {
  id         String   @id @default(cuid())
  vehicleId  String
  filename   String
  url        String
  uploadedAt DateTime @default(now())
  vehicle    Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
  @@map("vehicle_documents")
}

enum RoleType {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}
